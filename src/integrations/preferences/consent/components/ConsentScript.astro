---
// src/components/preferences/consent/ConsentScript.astro
/**
 * Consent Script Initialization
 *
 * Pure inline script - no bundling, no module preloading.
 * Sets up consent checking flag for components.
 */
---

<script is:inline>
  // Check if consent exists and mark it
  (function() {
    if (document.cookie.includes('cookie-consent=')) {
      window.__CONSENT_EXISTS__ = true;
    }
  })();
</script>